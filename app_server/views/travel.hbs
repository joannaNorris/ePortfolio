<div id="contents">
	<div class="box">
		<div>
			<div class="body">
				<h1>{{title}}</h1>

				<ul id="sites">
					{{#each trips}}
					<li>
						<a href="/api/trips/{{this.code}}">
						<img src="/images/{{image}}" alt="Img">
						</a>

						<h2>{{name}}</h2>

						<p>{{description}}</p>

					</li>
					{{/each}}
				</ul>
			</div>
		</div>
	</div>
</div>